{
  "uid": "botbonnie_app",
  "type": "app",
  "config": {
    "name": "${appName}",
    "description": "BotBonnie LINE messaging integration for HubSpot Workflows",
    "distribution": "private",
    "auth": {
      "type": "static",
      "requiredScopes": [
        "oauth",
        "crm.objects.contacts.read",
        "crm.objects.contacts.write",
        "timeline",
        "automation",
        "behavioral_events.event_definitions.read_write"
      ],
      "optionalScopes": [],
      "conditionallyRequiredScopes": []
    },
    "permittedUrls": {
      "fetch": [
        "https://api.botbonnie.com"
      ],
      "iframe": [],
      "img": []
    },
    "support": {
      "supportEmail": "",
      "documentationUrl": "",
      "supportUrl": "",
      "supportPhone": ""
    }
  }
}
