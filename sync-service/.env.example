# BotBonnie API Token (Console → Settings → Advanced → API TOKEN)
BOTBONNIE_API_TOKEN=

# BotBonnie LINE OA Page ID
BOTBONNIE_PAGE_ID=

# HubSpot Private App Access Token
PRIVATE_APP_ACCESS_TOKEN=

# HubSpot Personal Access Key (for setup scripts only, from hubspot.config.yml)
HS_PERSONAL_ACCESS_KEY=

# Sync interval in cron format (default: every 15 minutes)
SYNC_CRON=*/15 * * * *
